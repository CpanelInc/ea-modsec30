+    // cPanel/WebPros (EA-13497): on a shared-hosting box, each virtual host's
+    // requests run as that account's own UID (mod_ruid2), so the day/time
+    // audit directories below get created by whichever account's request
+    // happens to be first. The default process umask (0022, standard for
+    // httpd) silently strips any group/other write bits from
+    // getDirectoryPermission()'s requested mode before mkdir() ever sees it,
+    // so no SecAuditLogDirMode value alone can make these directories
+    // writable by a later request running as a different UID - every
+    // subsequent transaction under a different account then fails to log
+    // ("Not able to create directory: ... Permission denied") with no
+    // visible error to the admin. Force the requested mode through
+    // verbatim for just these two mkdir calls, matching the same
+    // sticky+world-writable model this package already uses for the
+    // top-level SecAuditLogStorageDir (%attr(1733 root root) in
+    // ea-modsec30-connector-apache24's spec).
+    mode_t orig_umask = umask(0);
     ret = utils::createDir((logPath +
         logFilePath(&transaction->m_timeStamp, YearMonthDayDirectory)).c_str(),
         m_audit->getDirectoryPermission(),
         error);
     if (ret == false) {
+        umask(orig_umask);
         return false;
     }
     ret = utils::createDir((logPath +
@@ -142,6 +159,7 @@
             | YearMonthDayAndTimeDirectory)).c_str(),
         m_audit->getDirectoryPermission(),
         error);
+    umask(orig_umask);
     if (ret == false) {
